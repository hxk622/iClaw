{
  "name": "iclaw-monorepo",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10",
  "scripts": {
    "dev": "pnpm dev:all",
    "version:set": "bash scripts/version.sh",
    "dev:all": "bash scripts/dev-all.sh",
    "dev:api": "bash scripts/dev-api.sh",
    "dev:web": "bash scripts/dev-web.sh",
    "dev:home": "pnpm --dir home dev",
    "build:home": "pnpm --dir home build",
    "dev:desktop": "pnpm --filter @iclaw/desktop dev --host 0.0.0.0 --port 1520",
    "build:desktop": "pnpm --filter @iclaw/desktop build",
    "tauri:dev": "pnpm --filter @iclaw/desktop tauri:dev",
    "tauri:build": "pnpm --filter @iclaw/desktop tauri:build"
  }
}
