{
  "name": "iclaw-monorepo",
  "private": true,
  "version": "1.0.0+202603091514",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "pnpm dev:all",
    "sync:clawhub:top": "pnpm --filter @iclaw/control-plane sync:clawhub:top",
    "env:dev": "bash scripts/env.sh dev",
    "env:test": "bash scripts/env.sh test",
    "env:prod": "bash scripts/env.sh prod",
    "env:switch": "bash scripts/env.sh",
    "version:set": "bash scripts/version.sh",
    "dev:all": "bash scripts/with-env.sh dev bash scripts/dev-all.sh",
    "db:init:control-plane": "bash scripts/init-control-plane-db.sh",
    "dev:control-plane:bg": "bash scripts/with-env.sh dev bash scripts/dev-control-plane.sh",
    "dev:api": "bash scripts/with-env.sh dev bash scripts/dev-api.sh",
    "dev:web": "bash scripts/with-env.sh dev bash scripts/dev-web.sh",
    "dev:control-plane": "bash scripts/with-env.sh dev env ICLAW_CONTROL_PLANE_DETACH=0 bash scripts/dev-control-plane.sh",
    "preset:sync:oem": "bash scripts/with-env.sh ${NODE_ENV:-dev} pnpm --filter @iclaw/control-plane preset:sync:oem",
    "dev:home": "pnpm dev:home-web",
    "build:home": "pnpm build:home-web",
    "dev:home-web": "bash scripts/with-env.sh dev pnpm --dir home-web dev",
    "build:home-web": "bash scripts/with-env.sh ${NODE_ENV:-prod} pnpm --dir home-web build",
    "dev:admin": "bash scripts/with-env.sh dev pnpm --dir admin-web dev",
    "build:admin": "bash scripts/with-env.sh ${NODE_ENV:-prod} pnpm --dir admin-web build",
    "check:control-plane": "pnpm --filter @iclaw/control-plane check",
    "build:openclaw-runtime": "bash scripts/build-openclaw-runtime.sh",
    "publish:openclaw-runtime": "bash scripts/publish-openclaw-runtime.sh",
    "dev:desktop": "bash scripts/with-env.sh dev pnpm --filter @iclaw/desktop dev --host 0.0.0.0 --port 1520 --strictPort",
    "build:desktop": "bash scripts/with-env.sh ${NODE_ENV:-prod} pnpm --filter @iclaw/desktop build",
    "tauri:dev": "bash scripts/with-env.sh ${NODE_ENV:-dev} pnpm --filter @iclaw/desktop tauri:dev",
    "tauri:build": "bash scripts/with-env.sh ${NODE_ENV:-dev} node scripts/build-desktop-package.mjs"
  },
  "devDependencies": {
    "semver": "6.3.1"
  }
}
