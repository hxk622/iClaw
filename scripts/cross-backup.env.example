# shellcheck shell=bash

# Optional: reuse the app's existing env instead of duplicating local secrets here.
if [[ -f /opt/iclaw/.env.prod ]]; then
  set -a
  # shellcheck disable=SC1091
  source /opt/iclaw/.env.prod
  set +a
fi

# A stable node label. Use a different value on each server.
ICLAW_CROSS_BACKUP_NODE_NAME="aliyun-prod"

# Local scratch directory for pg dumps and manifests.
ICLAW_CROSS_BACKUP_LOCAL_TMP_DIR="/var/tmp/iclaw-cross-backup"

# PostgreSQL: leave schema empty to dump the full database.
ICLAW_CROSS_BACKUP_PG_ENABLED="1"
ICLAW_CROSS_BACKUP_PG_URL="${DATABASE_URL:-postgresql://iclaw_app:change-me@127.0.0.1:5432/iclaw_control_prod}"
ICLAW_CROSS_BACKUP_PG_SCHEMA="app"
ICLAW_CROSS_BACKUP_PG_LABEL="control-plane"
ICLAW_CROSS_BACKUP_PG_BUCKET="iclaw-cross-backup-postgres"
ICLAW_CROSS_BACKUP_PG_PREFIX="${ICLAW_CROSS_BACKUP_NODE_NAME}/current"
ICLAW_CROSS_BACKUP_PG_OBJECT_NAME="${ICLAW_CROSS_BACKUP_NODE_NAME}-control-plane.dump"

# Local S3 / MinIO credentials.
ICLAW_CROSS_BACKUP_S3_ENABLED="1"
ICLAW_CROSS_BACKUP_S3_SOURCE_ENDPOINT="${S3_ENDPOINT:-http://127.0.0.1:9000}"
ICLAW_CROSS_BACKUP_S3_SOURCE_ACCESS_KEY="${S3_ACCESS_KEY:-openalpha}"
ICLAW_CROSS_BACKUP_S3_SOURCE_SECRET_KEY="${S3_SECRET_KEY:-change-me}"
ICLAW_CROSS_BACKUP_S3_BUCKETS="iclaw-files,licaiclaw-files,iclaw-user-assets"

# Peer S3 / MinIO endpoint. Each server points to the other server here.
ICLAW_CROSS_BACKUP_S3_TARGET_ENDPOINT="http://47.93.231.197:9000"
ICLAW_CROSS_BACKUP_S3_TARGET_ACCESS_KEY="openalpha"
ICLAW_CROSS_BACKUP_S3_TARGET_SECRET_KEY="change-me"

# Backup buckets live on the peer MinIO instance.
ICLAW_CROSS_BACKUP_S3_BACKUP_BUCKET_PREFIX="iclaw-cross-backup"
ICLAW_CROSS_BACKUP_MANIFEST_BUCKET="iclaw-cross-backup-manifests"
ICLAW_CROSS_BACKUP_MANIFEST_PREFIX="${ICLAW_CROSS_BACKUP_NODE_NAME}"
ICLAW_CROSS_BACKUP_MANIFEST_OBJECT_NAME="latest.txt"

# Single-copy overwrite mode: keep only the latest mirrored state on the peer.
ICLAW_CROSS_BACKUP_ENABLE_VERSIONING="0"
ICLAW_CROSS_BACKUP_S3_MIRROR_REMOVE="1"
