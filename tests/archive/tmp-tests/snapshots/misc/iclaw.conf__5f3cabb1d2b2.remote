server {
    listen 80;
    server_name iclaw-admin.aiyuanxi.com;

    location ^~ /.well-known/acme-challenge/ {
        root /var/www/caiclaw/admin;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    if ($host = iclaw.aiyuanxi.com) {
        return 301 https://$host$request_uri;
    }

    listen 80;
    server_name iclaw.aiyuanxi.com;
    return 404;
}
