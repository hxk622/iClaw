{
  "name": "@iclaw/control-plane",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node ../../scripts/write-build-info.mjs --component control-plane --package services/control-plane/package.json --out services/control-plane/build-info.json",
    "dev": "node --watch-path=src --experimental-strip-types src/server.ts",
    "prestart": "node ../../scripts/write-build-info.mjs --component control-plane --package services/control-plane/package.json --out services/control-plane/build-info.json",
    "start": "node --experimental-strip-types src/server.ts",
    "check": "tsc --noEmit",
    "test": "node --experimental-strip-types --test src/config.test.ts src/desktop-update-resolver.test.ts src/desktop-updates.test.ts src/portal-desktop-release.test.ts src/portal-runtime.test.ts src/service.test.ts src/time.test.ts",
    "baseline:apply": "node --experimental-strip-types scripts/apply-db-baseline.ts",
    "baseline:export": "node --experimental-strip-types scripts/export-db-baseline.ts",
    "baseline:doctor": "node --experimental-strip-types scripts/doctor-db-baseline.ts",
    "sync:clawhub:top": "node --experimental-strip-types scripts/sync-clawhub-top-skills.ts",
    "sync:clawhub:all": "node --experimental-strip-types scripts/sync-clawhub-top-skills.ts --limit 0",
    "upload:cloud-skill-artifacts": "node --experimental-strip-types scripts/upload-cloud-skill-artifacts.ts",
    "publish:external-cloud-skill": "node --experimental-strip-types scripts/publish-external-cloud-skill.ts",
    "publish:github-cloud-skill": "node --experimental-strip-types scripts/publish-github-cloud-skill.ts",
    "migrate:skill-catalog-table": "node --experimental-strip-types scripts/migrate-skill-catalog-table.ts",
    "migrate:canonical-session-keys": "node --experimental-strip-types scripts/migrate-canonical-session-keys.ts",
    "import:a-share-stocks": "node --experimental-strip-types scripts/import-a-share-stocks.ts",
    "import:cn-funds": "node --experimental-strip-types scripts/import-cn-funds.ts",
    "sync:local-app-runtime": "node --experimental-strip-types scripts/sync-local-app-runtime.ts",
    "sync:local-app-brand-profile": "node --experimental-strip-types scripts/sync-local-app-brand-profile.ts",
    "sync:system-overrides": "node --experimental-strip-types scripts/sync-system-overrides.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1005.0",
    "@iclaw/shared": "workspace:*",
    "pg": "^8.16.3",
    "redis": "^5.8.2"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/pg": "^8.15.5",
    "typescript": "^5.9.2"
  }
}
