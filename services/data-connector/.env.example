# Database configuration
DB_URL=postgres://iclaw_app:change_me_now@127.0.0.1:5432/iclaw_control

# Service configuration
PORT=2131
HOST=0.0.0.0
WORKERS=2

# Logging configuration
LOG_LEVEL=INFO
LOG_DIR=./logs

# Environment
ENV=dev

# Sync task configuration
SYNC_MODE=microservice # local or microservice
SYNC_AKSHARE_ENABLED=true
SYNC_EFINANCE_ENABLED=true
SYNC_DATA_VALIDATION_THRESHOLD=4000 # Minimum number of stocks to validate

# Scheduler configuration
SCHEDULER_ENABLED=true # Whether to enable built-in task scheduler
SCHEDULER_TIMEZONE=Asia/Shanghai # Timezone for scheduled tasks

# Advanced Sync Configuration
# Enable incremental sync (only update changed records)
ENABLE_INCREMENTAL_SYNC=true
# Maximum concurrent sync tasks
MAX_CONCURRENT_TASKS=2
# Maximum retry attempts for failed tasks
MAX_RETRY_ATTEMPTS=3
# Initial delay between retries (seconds)
RETRY_DELAY=1
# Backoff multiplier for retries
RETRY_BACKOFF=2
# Maximum delay between retries (seconds)
MAX_RETRY_DELAY=30

# Data Source Configuration
# Data source priority (comma-separated)
DATA_SOURCE_PRIORITY=akshare,efinance,tushare
# Request timeout for data sources (seconds)
DATA_SOURCE_TIMEOUT=30
# Maximum concurrent requests per data source
MAX_DATA_SOURCE_CONCURRENCY=5

# Distributed Lock Configuration
# Default lock TTL (seconds)
DEFAULT_LOCK_TTL=1800
# Enable automatic lock renewal
ENABLE_LOCK_RENEWAL=true

# Validation Configuration
# Minimum number of records to accept sync
MIN_RECORD_THRESHOLD=4000
# Enable data integrity checks
ENABLE_DATA_VALIDATION=true
