{
  "mcpServers": {
    "alpaca": {
      "enabled": true,
      "command": "uvx",
      "args": [
        "--from",
        "alpaca-mcp-server",
        "alpaca-mcp-server",
        "serve"
      ],
      "env": {
        "UV_NATIVE_TLS": "true",
        "UV_INDEX_URL": "https://mirrors.aliyun.com/pypi/simple/",
        "ALPACA_API_KEY": "${ALPACA_API_KEY}",
        "ALPACA_SECRET_KEY": "${ALPACA_SECRET_KEY}",
        "ALPACA_PAPER": "true"
      }
    },
    "alphavantage": {
      "enabled": true,
      "command": "uvx",
      "args": [
        "av-mcp",
        "HA0U7PHO7KC3O8BK"
      ],
      "env": {
        "UV_NATIVE_TLS": "true",
        "UV_INDEX_URL": "https://mirrors.aliyun.com/pypi/simple/"
      }
    },
    "browser": {
      "command": "node",
      "args": [
        "__ICLAW_SERVERS_DIR__/agent-browser/index.mjs"
      ],
      "enabled": true
    },
    "dbt": {
      "command": "uvx",
      "args": [
        "--from",
        "dbt-mcp",
        "dbt-mcp"
      ],
      "env": {
        "UV_NATIVE_TLS": "true",
        "UV_INDEX_URL": "https://mirrors.aliyun.com/pypi/simple/"
      },
      "enabled": true
    },
    "fingpt": {
      "command": "uv",
      "args": [
        "run",
        "--native-tls",
        "--index-url",
        "https://mirrors.aliyun.com/pypi/simple/",
        "__ICLAW_SERVERS_DIR__/fingpt/server.py"
      ],
      "env": {
        "FINGPT_API_URL": "${FINGPT_API_URL}",
        "UV_NATIVE_TLS": "true"
      },
      "enabled": true
    },
    "fmp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "financial-modeling-prep-mcp-server",
        "--port",
        "4010"
      ],
      "httpUrl": "http://127.0.0.1:4010/mcp",
      "env": {
        "FMP_ACCESS_TOKEN": "${FMP_ACCESS_TOKEN}",
        "FMP_API_KEY": "${FMP_ACCESS_TOKEN}",
        "PORT": "4010"
      },
      "enabled": true
    },
    "fred": {
      "enabled": true,
      "command": "uvx",
      "args": [
        "fred-mcp"
      ],
      "env": {
        "FRED_API_KEY": "d7c660fd367ce87971af725b83e10823",
        "UV_NATIVE_TLS": "true",
        "UV_INDEX_URL": "https://mirrors.aliyun.com/pypi/simple/"
      }
    },
    "markitdown": {
      "enabled": true,
      "command": "uvx",
      "args": [
        "markitdown-mcp"
      ],
      "env": {
        "UV_NATIVE_TLS": "true",
        "UV_INDEX_URL": "https://mirrors.aliyun.com/pypi/simple/"
      }
    },
    "nano-banana": {
      "command": "npx",
      "args": [
        "-y",
        "@aeven/nanobanana-mcp@latest"
      ],
      "env": {
        "MODEL_API_KEY": "${MODEL_API_KEY}"
      },
      "enabled": true
    },
    "sec-edgar": {
      "enabled": true,
      "command": "uvx",
      "args": [
        "--from",
        "sec-edgar-mcp",
        "sec-edgar-mcp"
      ],
      "env": {
        "UV_NATIVE_TLS": "true",
        "UV_INDEX_URL": "https://mirrors.aliyun.com/pypi/simple/",
        "SEC_EDGAR_USER_AGENT": "${SEC_EDGAR_USER_AGENT}"
      }
    },
    "serper": {
      "command": "npx",
      "args": [
        "-y",
        "serper-search-scrape-mcp-server"
      ],
      "env": {
        "SERPER_API_KEY": "${SERPER_API_KEY}"
      },
      "enabled": true
    },
    "tavily": {
      "command": "npx",
      "args": [
        "-y",
        "tavily-mcp@latest"
      ],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      },
      "enabled": true
    },
    "yahoo-finance": {
      "enabled": true,
      "command": "uvx",
      "args": [
        "mcp-yahoo-finance"
      ],
      "env": {
        "UV_NATIVE_TLS": "true",
        "UV_INDEX_URL": "https://mirrors.aliyun.com/pypi/simple/"
      }
    }
  }
}
