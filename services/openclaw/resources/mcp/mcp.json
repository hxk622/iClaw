{
  "mcpServers": {
    "alpaca": {
      "command": "uvx",
      "enabled": true
    },
    "browser": {
      "args": [
        "__ICLAW_SERVERS_DIR__/agent-browser/index.mjs"
      ],
      "command": "node",
      "source_layer": "platform",
      "managed_by": "platform",
      "locked": true,
      "enabled": true
    },
    "alphavantage": {
      "command": "uvx",
      "enabled": true
    },
    "markitdown": {
      "args": [
        "markitdown-mcp"
      ],
      "command": "uvx",
      "source_layer": "platform",
      "managed_by": "platform",
      "locked": true,
      "enabled": true
    },
    "tavily": {
      "args": [
        "-y",
        "tavily-mcp@latest"
      ],
      "command": "npx",
      "source_layer": "platform",
      "managed_by": "platform",
      "locked": true,
      "enabled": true
    },
    "dbt": {
      "command": "uvx",
      "enabled": true
    },
    "serper": {
      "args": [
        "-y",
        "serper-search-scrape-mcp-server"
      ],
      "command": "npx",
      "source_layer": "platform",
      "managed_by": "platform",
      "locked": true,
      "enabled": true
    },
    "fingpt": {
      "command": "uv",
      "enabled": true
    },
    "yahoo-finance": {
      "args": [
        "mcp-yahoo-finance"
      ],
      "command": "uvx",
      "source_layer": "platform",
      "managed_by": "platform",
      "locked": true,
      "enabled": true
    },
    "fmp": {
      "command": "npx",
      "enabled": true
    },
    "fred": {
      "command": "uvx",
      "enabled": true
    },
    "nano-banana": {
      "env": {
        "GEMINI_API_KEY": "${GEMINI_API_KEY}",
        "NANO_BANANA_MODEL": "${NANO_BANANA_MODEL}",
        "GOOGLE_GEMINI_BASE_URL": "${GOOGLE_GEMINI_BASE_URL}"
      },
      "args": [
        "__ICLAW_SERVERS_DIR__/nano-banana/index.mjs"
      ],
      "command": "node",
      "enabled": true
    },
    "sec-edgar": {
      "command": "uvx",
      "enabled": true
    }
  }
}
