# iClaw test environment
# Frontend dev origin is fixed at http://127.0.0.1:1520
# OAuth callback page lives on the frontend origin, not on the auth backend.
PORT=1420
VITE_API_BASE_URL=http://127.0.0.1:2126
VITE_AUTH_BASE_URL=http://127.0.0.1:2130
VITE_GATEWAY_TOKEN=iclaw-local-test-gateway-token
VITE_SIDE_CAR_ARGS=--port 2126
DATABASE_URL=postgres://iclaw_app:change_me@127.0.0.1:5432/iclaw_control_test
CONTROL_PLANE_REDIS_URL=redis://127.0.0.1:6379/1
CONTROL_PLANE_REDIS_KEY_PREFIX=iclaw:control-plane:test
CONTROL_PLANE_SUPER_ADMIN_EMAILS=515177265@qq.com
VITE_WECHAT_APP_ID=
# Example: http://127.0.0.1:1520/oauth-callback.html
VITE_WECHAT_OAUTH_REDIRECT_URI=
VITE_GOOGLE_CLIENT_ID=
# Example: http://127.0.0.1:1520/oauth-callback.html
VITE_GOOGLE_OAUTH_REDIRECT_URI=
VITE_BUILD_CHANNEL=test
