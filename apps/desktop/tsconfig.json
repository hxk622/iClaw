{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "experimentalDecorators": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@openclaw-ui/*": ["../../../openclaw/ui/src/*"],
      "@lydell/node-pty": ["src/types/vendor-stubs/node-pty.d.ts"],
      "@slack/bolt": ["src/types/vendor-stubs/slack-bolt.d.ts"],
      "pdfjs-dist/legacy/build/pdf.mjs": ["src/types/vendor-stubs/pdfjs-dist.d.ts"],
      "qrcode-terminal/vendor/QRCode/index.js": ["src/types/vendor-stubs/qrcode-terminal-index.d.ts"],
      "qrcode-terminal/vendor/QRCode/QRErrorCorrectLevel.js": ["src/types/vendor-stubs/qrcode-terminal-error-level.d.ts"]
    }
  },
  "include": ["src"]
}
