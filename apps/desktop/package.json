{
  "name": "@iclaw/desktop",
  "version": "1.0.0+202603091514",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node ../../scripts/apply-brand.mjs",
    "dev": "vite",
    "prebuild": "node ../../scripts/brand-generated-state.mjs snapshot desktop-build && node ../../scripts/apply-brand.mjs",
    "build": "vite build",
    "postbuild": "node ../../scripts/brand-generated-state.mjs restore desktop-build",
    "preview": "vite preview",
    "pretauri:dev": "node ../../scripts/apply-brand.mjs",
    "tauri:dev": "tauri dev --config src-tauri/tauri.generated.conf.json",
    "pretauri:build": "node ../../scripts/brand-generated-state.mjs snapshot desktop-tauri-build && node ../../scripts/apply-brand.mjs",
    "tauri:build": "node ../../scripts/build-desktop-package.mjs",
    "posttauri:build": "node ../../scripts/brand-generated-state.mjs restore desktop-tauri-build"
  },
  "dependencies": {
    "@iclaw/shared": "workspace:*",
    "@iclaw/sdk": "workspace:*",
    "@noble/ed25519": "3.0.0",
    "@tauri-apps/api": "^2.8.0",
    "dompurify": "^3.3.2",
    "lit": "^3.3.2",
    "lucide-react": "^0.544.0",
    "marked": "^17.0.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.12",
    "@tauri-apps/cli": "^2.8.5",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "agentation": "^2.3.3",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.9.2",
    "vite": "^6.3.5"
  }
}
