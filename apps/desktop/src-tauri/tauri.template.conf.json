{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "__BRAND_PRODUCT_NAME__",
  "version": "1.0.9+202604171540",
  "identifier": "ai.iclaw.desktop",
  "build": {
    "beforeDevCommand": "node ../../scripts/sync-openclaw-resources.mjs && pnpm dev --host 0.0.0.0 --port 1520",
    "beforeBuildCommand": "node ../../scripts/sync-openclaw-resources.mjs && pnpm build",
    "devUrl": "http://127.0.0.1:1520",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "__BRAND_PRODUCT_NAME__",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "nsis"
    ],
    "resources": [
      "resources/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  }
}
