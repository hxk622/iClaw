{
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "golden-dev-token"
    },
    "controlUi": {
      "allowedOrigins": [
        "http://127.0.0.1:1520",
        "http://localhost:1520"
      ],
      "allowInsecureAuth": true
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai/gpt-5.4"
      },
      "models": {
        "openai/gpt-5.4": {},
        "deepseek/deepseek-v3.2": {}
      },
      "workspace": "/tmp/iclaw-golden-dev-workspace",
      "compaction": {
        "mode": "safeguard"
      },
      "thinkingDefault": "xhigh",
      "timeoutSeconds": 1800,
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    }
  },
  "models": {
    "providers": {
      "openai": {
        "api": "openai-completions",
        "authHeader": true,
        "baseUrl": "https://fast.vpsairobot.com/v1",
        "apiKey": "sk-test-runtime",
        "models": [
          {
            "id": "gpt-5.4",
            "name": "GPT 5.4",
            "reasoning": true,
            "input": [
              "text",
              "image"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 272000,
            "maxTokens": 128000
          }
        ]
      },
      "deepseek": {
        "api": "openai-completions",
        "authHeader": true,
        "baseUrl": "https://api.deepseek.com/v1",
        "apiKey": "",
        "models": [
          {
            "id": "deepseek-v3.2",
            "name": "DeepSeek V3.2",
            "reasoning": true,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 128000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "plugins": {
    "slots": {
      "memory": "memory-lancedb"
    },
    "entries": {
      "memory-lancedb": {
        "config": {
          "embedding": {
            "apiKey": "sk-test-runtime",
            "model": "text-embedding-3-small",
            "baseUrl": "https://fast.vpsairobot.com/v1"
          },
          "autoRecall": false,
          "autoCapture": false
        }
      }
    }
  }
}
