{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "理财客",
  "version": "1.0.11+202604201058",
  "identifier": "ai.caiclaw.desktop",
  "build": {
    "beforeDevCommand": "bash ../../scripts/dev-web.sh",
    "beforeBuildCommand": "node ../../scripts/sync-openclaw-resources.mjs && pnpm build",
    "devUrl": "http://127.0.0.1:1520",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "理财客",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "nsis"
    ],
    "resources": [
      "resources/**/*"
    ],
    "icon": [
      "icons-generated/32x32.png",
      "icons-generated/128x128.png",
      "icons-generated/128x128@2x.png",
      "icons-generated/icon.icns",
      "icons-generated/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerIcon": "installer-generated/nsis-installer.ico"
      }
    },
    "createUpdaterArtifacts": false
  }
}
