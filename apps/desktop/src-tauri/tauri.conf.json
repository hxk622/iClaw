{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "iClaw",
  "version": "0.1.0",
  "identifier": "ai.openalpha.iclaw",
  "build": {
    "beforeDevCommand": "bash ../../scripts/sync-openclaw-resources.sh && bash ../../scripts/build-openclaw.sh || true && pnpm dev --host 0.0.0.0 --port 1420",
    "beforeBuildCommand": "bash ../../scripts/sync-openclaw-resources.sh && bash ../../scripts/build-openclaw.sh && pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "iClaw",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "externalBin": ["binaries/openclaw"],
    "targets": ["dmg", "nsis"],
    "resources": ["resources/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
