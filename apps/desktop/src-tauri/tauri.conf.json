{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "理财客",
  "version": "1.0.7+202604152241",
  "identifier": "ai.licaiclaw.desktop",
  "build": {
    "beforeDevCommand": "node ../../scripts/sync-openclaw-resources.mjs && pnpm dev --host 0.0.0.0 --port 1520",
    "beforeBuildCommand": "node ../../scripts/sync-openclaw-resources.mjs && pnpm build",
    "devUrl": "http://127.0.0.1:1520",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "理财客",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQzRDYzMjk4RDdFNzAwODIKUldTQ0FPZlhtRExXUXlkR1RTa2JxQU9yY3BpZWhyL3FzWWkvcUM1VDBMcE9sRCtPUFhPVUV0Z3gK"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "nsis"
    ],
    "resources": [
      "resources/**/*"
    ],
    "icon": [
      "icons-generated/32x32.png",
      "icons-generated/128x128.png",
      "icons-generated/128x128@2x.png",
      "icons-generated/icon.icns",
      "icons-generated/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerIcon": "installer-generated/nsis-installer.ico"
      }
    },
    "createUpdaterArtifacts": false
  }
}
