{
  "name": "@iclaw/home-web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node ../scripts/apply-brand.mjs",
    "dev": "vite --host 0.0.0.0 --port 1477",
    "prebuild": "node ../scripts/brand-generated-state.mjs snapshot home-web-build && node ../scripts/apply-brand.mjs",
    "build": "vite build",
    "postbuild": "node ../scripts/brand-generated-state.mjs restore home-web-build",
    "preview": "vite preview --host 0.0.0.0 --port 1478"
  },
  "devDependencies": {
    "vite": "^6.4.1"
  }
}
